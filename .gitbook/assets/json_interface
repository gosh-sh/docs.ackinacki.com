</span></span><span class="highlight-line"><span class="highlight-line-content">    resolve: (result: any) =&gt; void,<!-- -->
</span></span><span class="highlight-line"><span class="highlight-line-content">    reject: (error: Error) =&gt; void,<!-- -->
